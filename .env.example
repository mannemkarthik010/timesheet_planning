# --- Postgres ---
# Owner/migration connection: runs migrations, owns all tables/types.
# Local dev (docker-compose): postgres superuser.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/timesheet_dev

# Runtime app connection: the restricted `app_role` the API actually
# connects as at request time. Kept separate from DATABASE_URL so the
# app can never accidentally run with owner/superuser privileges —
# this is what makes the audit_logs INSERT-only lockdown and the RLS
# policies on timesheet_entries/payroll_payouts/pdf_reports meaningful.
# See apps/api/src/database/migrations for where app_role is created.
APP_DATABASE_URL=postgres://app_role:app_role_password@localhost:5432/timesheet_dev
APP_DB_PASSWORD=app_role_password

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
# Fallback defaults; per-role session length ultimately comes from
# restaurant_settings.admin_session_timeout_minutes /
# employee_session_timeout_minutes once that module is wired up.
JWT_REFRESH_TTL_ADMIN_MINUTES=15
JWT_REFRESH_TTL_EMPLOYEE_MINUTES=60

# --- Twilio Verify (self-registration phone verification + admin 2FA) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# --- App ---
PORT=3000
NODE_ENV=development
